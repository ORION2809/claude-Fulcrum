{
  "name": "claude-fulcrum",
  "version": "2.0.0",
"description": "The operating system for AI-powered development — 25 agents, 112 skills, 62 commands, 4-signal hybrid memory, knowledge graphs, and cross-platform support for Claude Code, Codex, Cursor, Copilot & OpenCode",
  "keywords": [
    "claude-fulcrum",
    "claude-code",
    "ai",
    "agents",
    "skills",
    "hooks",
    "mcp",
    "rules",
    "claude",
    "anthropic",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices",
    "cursor",
    "cursor-ide",
    "opencode",
    "codex",
    "ai-agents",
    "multi-agent",
    "agent-orchestration",
    "swarm-intelligence",
    "model-context-protocol",
    "developer-tools",
    "devtools",
    "coding-assistant",
    "code-generation"
  ],
  "author": {
    "name": "Shreyas Suvarna",
    "url": "https://github.com/ORION2809"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ORION2809/claude-Fulcrum.git"
  },
  "homepage": "https://github.com/ORION2809/claude-Fulcrum#readme",
  "bugs": {
    "url": "https://github.com/ORION2809/claude-Fulcrum/issues"
  },
  "files": [
    ".agents/",
    ".codex/",
    ".cursor/",
    ".opencode/",
    "agents/",
    "commands/",
    "contexts/",
    "examples/",
    "hooks/",
    "manifests/",
    "mcp-configs/",
    "orchestration/",
    "plugins/",
    "rules/",
    "schemas/",
    "scripts/",
    "skills/",
    "AGENTS.md",
    "CLAUDE.md",
    ".claude-plugin/plugin.json",
    ".claude-plugin/README.md",
    "install.sh",
    "install.ps1"
  ],
  "bin": {
    "claude-fulcrum": "scripts/ecc.js",
    "cf-install": "scripts/install-apply.js"
  },
  "scripts": {
    "postinstall": "echo '\\n  Claude Fulcrum installed!\\n  Run: npx claude-fulcrum typescript\\n  Docs: https://github.com/ORION2809/claude-Fulcrum\\n'",
    "lint": "eslint . && markdownlint \"**/*.md\" --ignore node_modules",
    "harness:audit": "node scripts/harness-audit.js",
    "test": "node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node scripts/ci/validate-install-manifests.js && node scripts/ci/validate-no-personal-paths.js && node scripts/ci/catalog.js --text && node tests/run-all.js",
    "coverage": "c8 --all --include=\"scripts/**/*.js\" --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --reporter=text --reporter=lcov node tests/run-all.js"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "ajv": "^8.18.0",
    "c8": "^10.1.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}
