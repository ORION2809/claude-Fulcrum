{
  "$schema": "https://opencode.ai/config.json",
  "model": "local.moonshotai/kimi-k2-instruct",
  "small_model": "local.moonshotai/kimi-k2-instruct",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    "skills/coding-standards/SKILL.md",
    "skills/verification-loop/SKILL.md",
    "skills/strategic-compact/SKILL.md"
  ],
  "plugin": [
    "./plugins"
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent for development work",
      "mode": "primary",
      "model": "local.moonshotai/kimi-k2-instruct",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Software architecture specialist for system design.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/architect.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Expert code review specialist for quality, security, and maintainability.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/code-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation specialist.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/security-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "tdd-guide": {
      "description": "Test-Driven Development specialist enforcing 80%+ coverage.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/tdd-guide.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "build-error-resolver": {
      "description": "Build and type error resolution specialist.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/build-error-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "e2e-runner": {
      "description": "End-to-end testing specialist using Playwright.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/e2e-runner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "doc-updater": {
      "description": "Documentation and codemap specialist.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/doc-updater.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "refactor-cleaner": {
      "description": "Dead code cleanup and consolidation specialist.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/refactor-cleaner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "go-reviewer": {
      "description": "Expert Go code reviewer.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/go-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "go-build-resolver": {
      "description": "Go build error resolution specialist.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/go-build-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "database-reviewer": {
      "description": "PostgreSQL database specialist for query optimization and schema design.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/database-reviewer.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "code-graph-reviewer": {
      "description": "Knowledge-graph-powered code reviewer with blast-radius analysis.",
      "mode": "subagent",
      "model": "local.moonshotai/kimi-k2-instruct",
      "prompt": "{file:prompts/agents/code-graph-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan",
      "template": "{file:../commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ coverage",
      "template": "{file:../commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review code for quality, security, and maintainability",
      "template": "{file:../commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Run comprehensive security review",
      "template": "{file:../commands/security-scan.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build errors with minimal changes",
      "template": "{file:../commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "e2e": {
      "description": "Generate and run E2E tests with Playwright",
      "template": "{file:../commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    },
    "orchestrate": {
      "description": "Orchestrate multiple agents for complex tasks",
      "template": "{file:../commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "code-graph-build": {
      "description": "Build or update the code review knowledge graph",
      "template": "{file:../commands/code-graph-build.md}\n\n$ARGUMENTS",
      "agent": "code-graph-reviewer",
      "subtask": true
    },
    "code-graph-review": {
      "description": "Token-efficient delta review using knowledge graph",
      "template": "{file:../commands/code-graph-review.md}\n\n$ARGUMENTS",
      "agent": "code-graph-reviewer",
      "subtask": true
    }
  },
  "permission": {
    "mcp_*": "ask"
  }
}
