# ===========================
# Claude Fulcrum .gitignore
# ===========================

# Dependencies
node_modules/

# Build outputs
build/
dist/
dist-cjs/
out/
output/
coverage/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
*~

# IDE
.idea/
.vscode/*.log

# Logs
*.log
*.pid
*.pid.lock
*.seed
*.lcov
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*
mcp-server.log
swarm-debug.log
init-output.log
ui_*.log
logs/

# Temp files
*.tmp
*.temp
*.swo
*.swp
tmp/

# Python
*.py[cod]
*$py.class
*.egg
*.egg-info/
*.so
.Python
__pycache__/

# SQLite databases
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite-journal
*.sqlite-wal
claude-flow.db

# Test artifacts
test-output/
test-reports/
tests/logs/
tests/results/
.nyc_output/

# Claude Flow runtime
.claude-flow/
.agentic-flow/
.swarm/
.hive-mind/
.ruv-swarm/
.mcp.json
claude-flow
claude-flow-mcp-wrapper
claude-flow.config.json
hive-mind-prompt-*.txt
swarm-runs

# Memory & coordination (runtime state)
/memory/
!/memory/agents/README.md
!/memory/sessions/README.md
/coordination/
memory/backups/

# SPARC/Roo (not used)
.roo/
.roomodes
.research/

# Runtime state directories
.orchestration/
.claude/ecc/
.claude/settings.local.json
./claude/checkpoints/
undefined/

# Codex local configuration
.codex/

# Executables
*.exe
bin/claude-flow-*
!bin/claude-flow

# Misc generated
.cache/
.deno/
.turbo/
api-project/
package
upgrade-research/
upgrade_plan.txt

# Preserved paths
!v3/@claude-flow/
